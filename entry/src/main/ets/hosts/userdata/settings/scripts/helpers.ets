import { meow, meowLevel } from "../../../../catstypicalframework/utils/catsLogger";

/**
 * The parser to parse settings generated by legacy BrowserCats (<2.0).
 * Parses a JSON string into a record of string keys and values.
 * @param settingsText The JSON string to parse.
 * @returns A record of string keys and values.
 */
export function settingsParserJSON(settingsText: string): Record<string, string> {
  let startTime = Date.now();
  try {
    const jsonObj: Record<string, string> = JSON.parse(settingsText) as Record<string, string>;
    meow(`Finished jsonObj parsing in ${Date.now() - startTime} ms! Is this enough?`, 'parser][settingsParserJSON', meowLevel.INFO);
    return jsonObj;
  } catch (e) {
    meow(`Failed to parse settings JSON: ${e}`, 'parser][settingsParserJSON', meowLevel.ERROR);
    return {};
  }
}

/**
 * Predefined lookup table using object property hash lookup for O(1) complexity.
 * @author ChatGLM @ Apr 4 2026
 */
const JSON_ESCAPE_MAP: Record<number, string> = {
  0x5C: '\\\\', // Backslash
  0x22: '\\"',  // Double quote
  0x0A: '\\n',  // Line feed
  0x0D: '\\r',  // Carriage return
  0x09: '\\t',  // Tab
};

/**
 * Helper: Escaping control characters that must be escaped in JSON strings
 * @param str The string to escape.
 * @returns The escaped string.
 * @author ChatGLM @ Apr 4 2026
 */
export function escapeForJson(str: string): string {
  const len = str.length;
  // Pre-allocate array to avoid dynamic expansion overhead from push()
  const result = new Array<string>(len);
  let resultIndex = 0;

  for (let i = 0; i < len; i++) {
    const charCode = str.charCodeAt(i);
    const escaped = JSON_ESCAPE_MAP[charCode];

    if (escaped !== undefined) {
      // Matched common escape characters
      result[resultIndex++] = escaped;
    } else if (charCode < 0x20) {
      // Handle other ASCII control characters (0x00 - 0x1F)
      // Direct string concatenation is slightly faster than padStart here
      const hex = charCode.toString(16);
      result[resultIndex++] = '\\u00' + (hex.length === 1 ? '0' + hex : hex);
    } else {
      // Normal character, push directly to the array
      result[resultIndex++] = str[i];
    }
  }

  return result.join('');
}
