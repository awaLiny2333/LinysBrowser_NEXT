import { meow, meowLevel } from "../../../catstypicalframework/utils/catsLogger";

/**
 * The parser to parse settings generated by legacy BrowserCats (<2.0).
 * Parses a JSON string into a record of string keys and values.
 * @param settingsText The JSON string to parse.
 * @returns A record of string keys and values.
 */
export function settingsParserJSON(settingsText: string) {
  let startTime = Date.now();
  const jsonObj: Record<string, string> = JSON.parse(settingsText) as Record<string, string>;
  meow(`Finished jsonObj parsing in ${Date.now() - startTime} ms! Is this enough?`, 'parser][settingsParserJSON', meowLevel.INFO);
  return jsonObj;
}

/**
 * The parser to parse settings generated by newer BrowserCats (>=2.0).
 * Parses a V2 format string into a record of string keys and values.
 * @param settingsText The V2 format string to parse.
 * @returns A record of string keys and values.
 *
 * @tutorial
 * About the V2 format of settingsText:
 * key1:value1
 * key2:value2
 * ...
 * The values are treated as strings.
 */
export function settingsParserV2(settingsText: string) {
  let startTime = Date.now();
  let kvObj: Record<string, string> = {};

  // 1. Check and reject empty values
  if (!settingsText || settingsText.length === 0) {
    meow(`Empty settingsText provided. Returning empty kvObj.`, 'parser][settingsParserV2', meowLevel.WARN);
    return kvObj;
  }

  // 2. Split by newline
  const lines = settingsText.split('\n');

  // 3. Traverse and parse
  for (const line of lines) {

    if (line.length === 0) {
      continue;
    } // Skip empty lines

    // Find the first colon
    const colonIndex: number = line.indexOf(':');

    // Error tolerance: If there is no colon, or if the colon is in the first position (key is empty), skip the line.
    if (colonIndex > 0) {
      const key: string = line.substring(0, colonIndex);
      const value: string = line.substring(colonIndex + 1); // Take all the content after the colon as the value (allow the value to contain a colon)
      kvObj[key] = value;
    }
  }
  
  meow(`Finished kvObj parsing in ${Date.now() - startTime} ms! Is this enough?`, 'parser][settingsParserV2', meowLevel.INFO);
  return kvObj;
}
